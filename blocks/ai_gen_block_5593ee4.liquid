{% doc %}
  @prompt
    Add a “Safety & Comfort” block:
    
    • FDA-cleared materials
    • Painless for most users (gentle vibration)
    • Safe for all hair types and scalp sensitivities
    • Full instructions and support included
    
    
    6. CTA or Support Link
    
    Prompt:
    
    Finish with a simple CTA bar:
    
    • “Ready to try it? [Shop Nuvé Stamp Now]”
    • “Still have questions? [Contact Us] or see our FAQ.”
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-safety-comfort-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-safety-comfort-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-safety-comfort-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.spacing_after_heading }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-safety-comfort-features-{{ ai_gen_id }} {
    display: grid;
    gap: {{ block.settings.feature_spacing }}px;
    margin-bottom: {{ block.settings.spacing_before_cta }}px;
  }

  .ai-safety-comfort-feature-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .ai-safety-comfort-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
    color: {{ block.settings.icon_color }};
  }

  .ai-safety-comfort-icon-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
  }

  .ai-safety-comfort-text-{{ ai_gen_id }} {
    flex: 1;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-safety-comfort-cta-{{ ai_gen_id }} {
    background-color: {{ block.settings.cta_background }};
    border-radius: {{ block.settings.cta_border_radius }}px;
    padding: {{ block.settings.cta_padding }}px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    text-align: center;
  }

  .ai-safety-comfort-cta-row-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .ai-safety-comfort-cta-text-{{ ai_gen_id }} {
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_text_size }}px;
    margin: 0;
  }

  .ai-safety-comfort-cta-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .ai-safety-comfort-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-safety-comfort-cta-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    font-size: {{ block.settings.link_text_size }}px;
    transition: opacity 0.3s ease;
  }

  .ai-safety-comfort-cta-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .ai-safety-comfort-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-safety-comfort-container-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }

    .ai-safety-comfort-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-safety-comfort-cta-row-{{ ai_gen_id }} {
      flex-direction: column;
      width: 100%;
    }

    .ai-safety-comfort-cta-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-safety-comfort-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-safety-comfort-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-safety-comfort-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-safety-comfort-features-{{ ai_gen_id }}">
      {% if block.settings.feature_1_text != blank %}
        <div class="ai-safety-comfort-feature-{{ ai_gen_id }}">
          <div class="ai-safety-comfort-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <div class="ai-safety-comfort-text-{{ ai_gen_id }}">{{ block.settings.feature_1_text }}</div>
        </div>
      {% endif %}

      {% if block.settings.feature_2_text != blank %}
        <div class="ai-safety-comfort-feature-{{ ai_gen_id }}">
          <div class="ai-safety-comfort-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <div class="ai-safety-comfort-text-{{ ai_gen_id }}">{{ block.settings.feature_2_text }}</div>
        </div>
      {% endif %}

      {% if block.settings.feature_3_text != blank %}
        <div class="ai-safety-comfort-feature-{{ ai_gen_id }}">
          <div class="ai-safety-comfort-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <div class="ai-safety-comfort-text-{{ ai_gen_id }}">{{ block.settings.feature_3_text }}</div>
        </div>
      {% endif %}

      {% if block.settings.feature_4_text != blank %}
        <div class="ai-safety-comfort-feature-{{ ai_gen_id }}">
          <div class="ai-safety-comfort-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <div class="ai-safety-comfort-text-{{ ai_gen_id }}">{{ block.settings.feature_4_text }}</div>
        </div>
      {% endif %}
    </div>

    <div class="ai-safety-comfort-cta-{{ ai_gen_id }}">
      {% if block.settings.cta_primary_text != blank %}
        <div class="ai-safety-comfort-cta-row-{{ ai_gen_id }}">
          <p class="ai-safety-comfort-cta-text-{{ ai_gen_id }}">{{ block.settings.cta_primary_text }}</p>
          {% if block.settings.cta_primary_button_text != blank and block.settings.cta_primary_button_link != blank %}
            <a href="{{ block.settings.cta_primary_button_link }}" class="ai-safety-comfort-cta-button-{{ ai_gen_id }}">
              {{ block.settings.cta_primary_button_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.cta_secondary_text != blank %}
        <div class="ai-safety-comfort-cta-row-{{ ai_gen_id }}">
          <p class="ai-safety-comfort-cta-text-{{ ai_gen_id }}">{{ block.settings.cta_secondary_text }}</p>
          {% if block.settings.cta_contact_text != blank and block.settings.cta_contact_link != blank %}
            <a href="{{ block.settings.cta_contact_link }}" class="ai-safety-comfort-cta-link-{{ ai_gen_id }}">
              {{ block.settings.cta_contact_text }}
            </a>
          {% endif %}
          {% if block.settings.cta_faq_text != blank and block.settings.cta_faq_link != blank %}
            <span class="ai-safety-comfort-cta-text-{{ ai_gen_id }}">or</span>
            <a href="{{ block.settings.cta_faq_link }}" class="ai-safety-comfort-cta-link-{{ ai_gen_id }}">
              {{ block.settings.cta_faq_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>


{% doc %}
  @prompt
    Create a high-impact “Real Results” section for a premium hair regrowth brand, Nuvé Stamp.
    
    Headline: “See the Nuvé Stamp Difference”
    
    Feature types:
    
    • Before & After gallery — Show split or slider images of actual scalp transformations (thicker hair, denser hairline) with “Before” and “After” labels on each.
    • User testimonial quotes — Display 2-3 honest, relatable reviews with user names and (optional) small profile images.
    Example testimonial copy:
    “I started seeing new growth after just a month—and my barber even noticed!” – Alex M.
    “I tried everything. Only Nuvé Stamp made my part look fuller again.” – Priya S.
    “The vibrations made it so much less scary than regular rollers!” – Jack D.
    
    Design:
    
    • Visual grid or slider for before/after images.
    • Below that, testimonials as cards or in a scrolling carousel.
    • Brand colors (subtle lilac accent, white/near-black background)
    • Section should look trustworthy, authentic, and upbeat (not spammy).
    Optional CTA: “See More Results” or “Read All Reviews”
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-results-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-results-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-results-heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-results-gallery-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gallery_gap }}px;
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-results-comparison-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f5f5f5;
  }

  .ai-results-comparison-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-results-comparison-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-results-comparison-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-results-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-results-labels-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    pointer-events: none;
  }

  .ai-results-label-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: {{ block.settings.label_padding }}px;
  }

  .ai-results-label-text-{{ ai_gen_id }} {
    background-color: {{ block.settings.label_background }};
    color: {{ block.settings.label_text_color }};
    padding: 6px 12px;
    border-radius: {{ block.settings.label_border_radius }}px;
    font-size: {{ block.settings.label_font_size }}px;
    font-weight: 600;
  }

  .ai-results-divider-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 50%;
    width: 2px;
    height: 100%;
    background-color: {{ block.settings.divider_color }};
    transform: translateX(-50%);
  }

  .ai-results-testimonials-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.testimonial_columns }}, 1fr);
    gap: {{ block.settings.testimonial_gap }}px;
    margin-bottom: {{ block.settings.cta_spacing }}px;
  }

  .ai-results-testimonial-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-results-testimonial-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_font_size }}px;
    color: {{ block.settings.quote_color }};
    line-height: 1.6;
    margin: 0 0 16px;
  }

  .ai-results-testimonial-author-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-results-author-image-{{ ai_gen_id }} {
    width: {{ block.settings.author_image_size }}px;
    height: {{ block.settings.author_image_size }}px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .ai-results-author-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-results-author-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.background_color }};
    font-weight: 600;
    font-size: {{ block.settings.author_image_size | divided_by: 2 }}px;
  }

  .ai-results-author-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_font_size }}px;
    color: {{ block.settings.author_color }};
    font-weight: 600;
  }

  .ai-results-cta-wrapper-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-results-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: {{ block.settings.cta_border_width }}px solid {{ block.settings.cta_border_color }};
  }

  .ai-results-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    color: {{ block.settings.cta_hover_text_color }};
    border-color: {{ block.settings.cta_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-results-gallery-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-results-testimonials-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-results-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<nuve-results-{{ ai_gen_id }} class="ai-results-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-results-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-results-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-results-gallery-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign image_key = 'comparison_image_' | append: i
          assign comparison_image = block.settings[image_key]
        %}
        
        <div class="ai-results-comparison-{{ ai_gen_id }}">
          {% if comparison_image %}
            <img
              src="{{ comparison_image | image_url: width: 800 }}"
              alt="{{ comparison_image.alt | escape }}"
              loading="lazy"
              width="{{ comparison_image.width }}"
              height="{{ comparison_image.height }}"
              class="ai-results-comparison-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-results-comparison-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-results-empty-state-{{ ai_gen_id }}">
                Add before/after image {{ i }}
              </div>
            </div>
          {% endif %}
          
          <div class="ai-results-labels-{{ ai_gen_id }}">
            <div class="ai-results-label-{{ ai_gen_id }}">
              <span class="ai-results-label-text-{{ ai_gen_id }}">{{ block.settings.before_label }}</span>
            </div>
            <div class="ai-results-label-{{ ai_gen_id }}">
              <span class="ai-results-label-text-{{ ai_gen_id }}">{{ block.settings.after_label }}</span>
            </div>
          </div>
          
          <div class="ai-results-divider-{{ ai_gen_id }}"></div>
        </div>
      {% endfor %}
    </div>

    <div class="ai-results-testimonials-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign quote_key = 'testimonial_quote_' | append: i
          assign author_key = 'testimonial_author_' | append: i
          assign image_key = 'testimonial_image_' | append: i
          
          assign quote = block.settings[quote_key]
          assign author = block.settings[author_key]
          assign author_image = block.settings[image_key]
        %}
        
        {% if quote != blank %}
          <div class="ai-results-testimonial-card-{{ ai_gen_id }}">
            <p class="ai-results-testimonial-quote-{{ ai_gen_id }}">"{{ quote }}"</p>
            
            <div class="ai-results-testimonial-author-{{ ai_gen_id }}">
              <div class="ai-results-author-image-{{ ai_gen_id }}">
                {% if author_image %}
                  <img
                    src="{{ author_image | image_url: width: 100 }}"
                    alt="{{ author | escape }}"
                    loading="lazy"
                    width="100"
                    height="100"
                  >
                {% else %}
                  <div class="ai-results-author-placeholder-{{ ai_gen_id }}">
                    {% if author != blank %}
                      {{ author | slice: 0 }}
                    {% else %}
                      ?
                    {% endif %}
                  </div>
                {% endif %}
              </div>
              
              {% if author != blank %}
                <span class="ai-results-author-name-{{ ai_gen_id }}">{{ author }}</span>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if block.settings.show_cta and block.settings.cta_text != blank %}
      <div class="ai-results-cta-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.cta_link }}" class="ai-results-cta-{{ ai_gen_id }}">
          {{ block.settings.cta_text }}
        </a>
      </div>
    {% endif %}
  </div>
</nuve-results-{{ ai_gen_id }}>

<script>
  (function() {
    class NuveResults{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('nuve-results-{{ ai_gen_id }}', NuveResults{{ ai_gen_id }});
  })();
</script>


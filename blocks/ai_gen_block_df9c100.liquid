{% doc %}
  @prompt
    Add an FAQ section with categorized expandable accordions for a hair routine DTC brand, Nuvé Stamp.
    
    Categories and Questions:
    
    Getting Started
    
    • What is Nuvé Stamp and how does it work?
    • Who is Nuvé Stamp designed for?
    Device Use & Safety
    
    • Does it hurt to use?
    • How often should I use Nuvé Stamp for best results?
    • Can I use serums or oils with the device?
    • Is it safe for color-treated, curly, or sensitive scalps?
    Results
    
    • How soon will I see visible improvement?
    • How do I maximize my results?
    • What if I don’t see results?
    Orders & Shipping
    
    • How long does shipping take?
    • Can I track my order?
    • What is your return policy?
    Support
    
    • How can I contact customer support?
    • What do I do if there’s a problem with my device?
    Design:
    
    • Accordion/expandable Q&A, grouped by clear category headings
    • Mobile-friendly, modern, brand-aligned design with subtle lilac or off-white accents
    • At the bottom: Add a closing message and Contact Us link (“Didn’t find your question? [Contact us] for personal help.”)
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-faq-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-faq-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    font-weight: 700;
  }

  .ai-faq-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    opacity: 0.8;
  }

  .ai-faq-category-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-faq-category-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.category_title_size }}px;
    color: {{ block.settings.category_title_color }};
    margin: 0 0 16px 0;
    font-weight: 600;
    padding-bottom: 8px;
    border-bottom: 2px solid {{ block.settings.accent_color }};
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    margin-bottom: 12px;
    overflow: hidden;
    background-color: {{ block.settings.item_background }};
    transition: all 0.3s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.accent_color }};
  }

  .ai-faq-question-{{ ai_gen_id }} {
    width: 100%;
    padding: 18px 20px;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: {{ block.settings.question_size }}px;
    color: {{ block.settings.question_color }};
    font-weight: 600;
    transition: color 0.3s ease;
  }

  .ai-faq-question-{{ ai_gen_id }}:hover {
    color: {{ block.settings.accent_color }};
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    color: {{ block.settings.accent_color }};
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 500px;
    padding: 0 20px 18px 20px;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-faq-footer-{{ ai_gen_id }} {
    margin-top: 48px;
    padding: 32px;
    background-color: {{ block.settings.footer_background }};
    border-radius: {{ block.settings.border_radius }}px;
    text-align: center;
  }

  .ai-faq-footer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
  }

  .ai-faq-contact-link-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .ai-faq-contact-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 749px) {
    .ai-faq-container-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 16px;
    }

    .ai-faq-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-faq-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-faq-category-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.category_title_size | times: 0.85 }}px;
    }

    .ai-faq-question-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_size | times: 0.9 }}px;
      padding: 14px 16px;
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_size | times: 0.95 }}px;
    }

    .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
      padding: 0 16px 14px 16px;
    }

    .ai-faq-footer-{{ ai_gen_id }} {
      padding: 24px 16px;
    }
  }
{% endstyle %}


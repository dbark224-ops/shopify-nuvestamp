{% doc %}
  @prompt
    Create a visually appealing benefits grid for a premium hair regrowth brand, Nuvé Stamp.
    
    Headline: “Why Choose Nuvé Stamp?”
    
    Benefits (with bold, simple icons):
    
    1. Stimulates dormant hair follicles for fuller, thicker hair
    2. Combines microneedling, vibration, and red light therapy
    3. Pain-free, easy-to-use, and safe for home use
    4. Noticeable results in just 3–6 weeks for most users
    5. No drugs, chemicals, or invasive treatments
    6. Trusted by thousands of men and women worldwide
    Design:
    
    • 2–3 column layout on desktop, stacked on mobile
    • Each benefit has a matching icon or simple illustration (e.g., follicle, checkmark, home, clock, shield, heart)
    • Brand-aligned colors: near-black, soft lilac accents, clean off-white background
    • Optional: Add a “30-day See New Growth Guarantee” badge beneath the grid for extra trust
    CTA (optional): “See Real Results” or “How It Works”
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-benefits-grid__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-benefits-grid__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: 700;
  }

  .ai-benefits-grid__items-{{ ai_gen_id }} {
    display: grid;
    {% if block.settings.columns_desktop == '2' %}
      grid-template-columns: repeat(2, 1fr);
    {% else %}
      grid-template-columns: repeat(3, 1fr);
    {% endif %}
    gap: {{ block.settings.grid_gap }}px;
    margin-bottom: {{ block.settings.badge_spacing }}px;
  }

  .ai-benefits-grid__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.item_alignment }};
    text-align: {{ block.settings.item_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background }};
    border-radius: {{ block.settings.item_border_radius }}px;
    transition: transform 0.2s ease;
  }

  .ai-benefits-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-benefits-grid__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-benefits-grid__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-benefits-grid__badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.badge_padding_vertical }}px {{ block.settings.badge_padding_horizontal }}px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_text_size }}px;
    font-weight: 600;
    text-align: center;
    border: {{ block.settings.badge_border_width }}px solid {{ block.settings.badge_border_color }};
  }

  .ai-benefits-grid__badge-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.badge_alignment }};
    margin-bottom: {{ block.settings.cta_spacing }}px;
  }

  .ai-benefits-grid__cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.cta_padding_vertical }}px {{ block.settings.cta_padding_horizontal }}px;
    background-color: {{ block.settings.cta_background }};
    color: {{ block.settings.cta_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_border_radius }}px;
    font-size: {{ block.settings.cta_text_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .ai-benefits-grid__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_hover_background }};
    color: {{ block.settings.cta_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-benefits-grid__cta-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.cta_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-grid__items-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-benefits-grid__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-benefits-grid__icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size }}px * 0.8);
      height: calc({{ block.settings.icon_size }}px * 0.8);
    }
  }
{% endstyle %}

<benefits-grid-{{ ai_gen_id }} class="ai-benefits-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-grid__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-benefits-grid__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-benefits-grid__items-{{ ai_gen_id }}">
      {% if block.settings.benefit_1_enabled %}
        <div class="ai-benefits-grid__item-{{ ai_gen_id }}">
          <svg class="ai-benefits-grid__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="3"></circle>
            <path d="M12 11v10"></path>
            <path d="M8 15l4 4 4-4"></path>
          </svg>
          <p class="ai-benefits-grid__text-{{ ai_gen_id }}">{{ block.settings.benefit_1_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_2_enabled %}
        <div class="ai-benefits-grid__item-{{ ai_gen_id }}">
          <svg class="ai-benefits-grid__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M12 6v6l4 2"></path>
            <path d="M16 8l4-4"></path>
            <path d="M8 16l-4 4"></path>
          </svg>
          <p class="ai-benefits-grid__text-{{ ai_gen_id }}">{{ block.settings.benefit_2_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_3_enabled %}
        <div class="ai-benefits-grid__item-{{ ai_gen_id }}">
          <svg class="ai-benefits-grid__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          <p class="ai-benefits-grid__text-{{ ai_gen_id }}">{{ block.settings.benefit_3_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_4_enabled %}
        <div class="ai-benefits-grid__item-{{ ai_gen_id }}">
          <svg class="ai-benefits-grid__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <p class="ai-benefits-grid__text-{{ ai_gen_id }}">{{ block.settings.benefit_4_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_5_enabled %}
        <div class="ai-benefits-grid__item-{{ ai_gen_id }}">
          <svg class="ai-benefits-grid__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <path d="M9 12l2 2 4-4"></path>
          </svg>
          <p class="ai-benefits-grid__text-{{ ai_gen_id }}">{{ block.settings.benefit_5_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.benefit_6_enabled %}
        <div class="ai-benefits-grid__item-{{ ai_gen_id }}">
          <svg class="ai-benefits-grid__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
          </svg>
          <p class="ai-benefits-grid__text-{{ ai_gen_id }}">{{ block.settings.benefit_6_text }}</p>
        </div>
      {% endif %}
    </div>

    {% if block.settings.show_badge and block.settings.badge_text != blank %}
      <div class="ai-benefits-grid__badge-wrapper-{{ ai_gen_id }}">
        <div class="ai-benefits-grid__badge-{{ ai_gen_id }}">
          {{ block.settings.badge_text }}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_cta and block.settings.cta_text != blank %}
      <div class="ai-benefits-grid__cta-wrapper-{{ ai_gen_id }}">
        <a href="{{ block.settings.cta_link }}" class="ai-benefits-grid__cta-{{ ai_gen_id }}">
          {{ block.settings.cta_text }}
        </a>
      </div>
    {% endif %}
  </div>
</benefits-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class BenefitsGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('benefits-grid-{{ ai_gen_id }}', BenefitsGrid{{ ai_gen_id }});
  })();
</script>


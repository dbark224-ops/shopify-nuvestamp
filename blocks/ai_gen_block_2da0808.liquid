{% doc %}
  @prompt
    Create an “About Us” page for a science-driven hair regrowth brand, Nuvé Stamp.
    
    • Headline: “Our Story: Science, Hope, and Regrowth”
    • Mission: “We help men and women regain confidence through advanced, at-home hair regrowth solutions.”
    • Brand story: Origin of Nuvé Stamp, why it was created, what makes it unique.
    • Brand values: Science first, empathy, everyday confidence.
    • Optional: Team founder section, testimonial, lab-style or team photo.
    • Clean, visually reassuring design with brand color accents.
    • CTA: “See Real Results” or “Contact Support”
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-about-us-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-about-us-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-about-us-hero-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-about-us-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    line-height: 1.2;
  }

  .ai-about-us-mission-{{ ai_gen_id }} {
    font-size: {{ block.settings.mission_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.section_spacing }}px;
    line-height: 1.6;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-about-us-story-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-about-us-story-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.content_gap }}px;
    align-items: center;
  }

  @media (min-width: 768px) {
    .ai-about-us-story-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ai-about-us-story-text-{{ ai_gen_id }} {
    order: 1;
  }

  .ai-about-us-story-image-{{ ai_gen_id }} {
    order: 2;
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-about-us-story-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-about-us-story-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-about-us-story-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-about-us-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-about-us-section-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.section_title_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.text_spacing }}px;
    line-height: 1.3;
  }

  .ai-about-us-story-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.7;
  }

  .ai-about-us-values-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-about-us-values-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.content_gap }}px;
    margin-top: {{ block.settings.content_gap }}px;
  }

  @media (min-width: 768px) {
    .ai-about-us-values-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .ai-about-us-value-card-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    text-align: center;
    border: 1px solid {{ block.settings.card_border_color }};
  }

  .ai-about-us-value-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.text_spacing }}px;
    background-color: {{ block.settings.accent_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_color }};
    font-size: {{ block.settings.icon_size | times: 0.5 }}px;
    font-weight: bold;
  }

  .ai-about-us-value-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.value_title_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.text_spacing | divided_by: 2 }}px;
    font-weight: 600;
  }

  .ai-about-us-value-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-about-us-team-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-about-us-team-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.content_gap }}px;
    align-items: center;
    margin-top: {{ block.settings.content_gap }}px;
  }

  @media (min-width: 768px) {
    .ai-about-us-team-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ai-about-us-team-image-{{ ai_gen_id }} {
    width: 100%;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-about-us-team-image-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-about-us-team-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-about-us-team-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-about-us-team-info-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_spacing }}px;
  }

  .ai-about-us-founder-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.section_title_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0;
    font-weight: 600;
  }

  .ai-about-us-founder-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_text_size }}px;
    color: {{ block.settings.accent_color }};
    margin: 0;
    font-weight: 500;
  }

  .ai-about-us-founder-bio-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.7;
    margin: 0;
  }

  .ai-about-us-testimonial-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.testimonial_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    border-left: 4px solid {{ block.settings.accent_color }};
    text-align: center;
  }

  .ai-about-us-testimonial-quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.testimonial_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    font-style: italic;
    margin: 0 0 {{ block.settings.text_spacing }}px;
  }

  .ai-about-us-testimonial-author-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_text_size }}px;
    color: {{ block.settings.headline_color }};
    font-weight: 600;
    margin: 0;
  }

  .ai-about-us-cta-{{ ai_gen_id }} {
    text-align: center;
    margin-top: {{ block.settings.section_spacing }}px;
  }

  .ai-about-us-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_background }};
  }

  .ai-about-us-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_background }};
  }

  @media (max-width: 767px) {
    .ai-about-us-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-about-us-section-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.section_title_size | times: 0.8 }}px;
    }

    .ai-about-us-mission-{{ ai_gen_id }} {
      font-size: {{ block.settings.mission_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<about-us-{{ ai_gen_id }} class="ai-about-us-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-about-us-container-{{ ai_gen_id }}">
    {% if block.settings.show_hero %}
      <div class="ai-about-us-hero-{{ ai_gen_id }}">
        {% if block.settings.headline != blank %}
          <h1 class="ai-about-us-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
        {% endif %}
        {% if block.settings.mission != blank %}
          <div class="ai-about-us-mission-{{ ai_gen_id }}">{{ block.settings.mission }}</div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_story %}
      <div class="ai-about-us-story-{{ ai_gen_id }}">
        <div class="ai-about-us-story-content-{{ ai_gen_id }}">
          <div class="ai-about-us-story-text-{{ ai_gen_id }}">
            {% if block.settings.story_title != blank %}
              <h2 class="ai-about-us-section-title-{{ ai_gen_id }}">{{ block.settings.story_title }}</h2>
            {% endif %}
            {% if block.settings.story_description != blank %}
              <div class="ai-about-us-story-description-{{ ai_gen_id }}">{{ block.settings.story_description }}</div>
            {% endif %}
          </div>
          <div class="ai-about-us-story-image-{{ ai_gen_id }}">
            {% if block.settings.story_image %}
              <img
                src="{{ block.settings.story_image | image_url: width: 800 }}"
                alt="{{ block.settings.story_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.story_image.width }}"
                height="{{ block.settings.story_image.height }}"
              >
            {% else %}
              <div class="ai-about-us-story-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-about-us-empty-state-{{ ai_gen_id }}">
                  Add a brand story image
                </div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_values %}
      <div class="ai-about-us-values-{{ ai_gen_id }}">
        {% if block.settings.values_title != blank %}
          <h2 class="ai-about-us-section-title-{{ ai_gen_id }}" style="text-align: center;">{{ block.settings.values_title }}</h2>
        {% endif %}
        <div class="ai-about-us-values-grid-{{ ai_gen_id }}">
          <div class="ai-about-us-value-card-{{ ai_gen_id }}">
            <div class="ai-about-us-value-icon-{{ ai_gen_id }}">
              {{ block.settings.value_1_icon }}
            </div>
            <h3 class="ai-about-us-value-title-{{ ai_gen_id }}">{{ block.settings.value_1_title }}</h3>
            <p class="ai-about-us-value-description-{{ ai_gen_id }}">{{ block.settings.value_1_description }}</p>
          </div>
          <div class="ai-about-us-value-card-{{ ai_gen_id }}">
            <div class="ai-about-us-value-icon-{{ ai_gen_id }}">
              {{ block.settings.value_2_icon }}
            </div>
            <h3 class="ai-about-us-value-title-{{ ai_gen_id }}">{{ block.settings.value_2_title }}</h3>
            <p class="ai-about-us-value-description-{{ ai_gen_id }}">{{ block.settings.value_2_description }}</p>
          </div>
          <div class="ai-about-us-value-card-{{ ai_gen_id }}">
            <div class="ai-about-us-value-icon-{{ ai_gen_id }}">
              {{ block.settings.value_3_icon }}
            </div>
            <h3 class="ai-about-us-value-title-{{ ai_gen_id }}">{{ block.settings.value_3_title }}</h3>
            <p class="ai-about-us-value-description-{{ ai_gen_id }}">{{ block.settings.value_3_description }}</p>
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_team %}
      <div class="ai-about-us-team-{{ ai_gen_id }}">
        {% if block.settings.team_section_title != blank %}
          <h2 class="ai-about-us-section-title-{{ ai_gen_id }}" style="text-align: center;">{{ block.settings.team_section_title }}</h2>
        {% endif %}
        <div class="ai-about-us-team-content-{{ ai_gen_id }}">
          <div class="ai-about-us-team-image-{{ ai_gen_id }}">
            {% if block.settings.team_image %}
              <img
                src="{{ block.settings.team_image | image_url: width: 800 }}"
                alt="{{ block.settings.team_image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.team_image.width }}"
                height="{{ block.settings.team_image.height }}"
              >
            {% else %}
              <div class="ai-about-us-team-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
                <div class="ai-about-us-empty-state-{{ ai_gen_id }}">
                  Add a team or founder photo
                </div>
              </div>
            {% endif %}
          </div>
          <div class="ai-about-us-team-info-{{ ai_gen_id }}">
            {% if block.settings.founder_name != blank %}
              <h3 class="ai-about-us-founder-name-{{ ai_gen_id }}">{{ block.settings.founder_name }}</h3>
            {% endif %}
            {% if block.settings.founder_title != blank %}
              <p class="ai-about-us-founder-title-{{ ai_gen_id }}">{{ block.settings.founder_title }}</p>
            {% endif %}
            {% if block.settings.founder_bio != blank %}
              <div class="ai-about-us-founder-bio-{{ ai_gen_id }}">{{ block.settings.founder_bio }}</div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_testimonial and block.settings.testimonial_quote != blank %}
      <div class="ai-about-us-testimonial-{{ ai_gen_id }}">
        <p class="ai-about-us-testimonial-quote-{{ ai_gen_id }}">"{{ block.settings.testimonial_quote }}"</p>
        {% if block.settings.testimonial_author != blank %}
          <p class="ai-about-us-testimonial-author-{{ ai_gen_id }}">— {{ block.settings.testimonial_author }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_cta %}
      <div class="ai-about-us-cta-{{ ai_gen_id }}">
        {% if block.settings.cta_link != blank %}
          <a href="{{ block.settings.cta_link }}" class="ai-about-us-cta-button-{{ ai_gen_id }}">
            {{ block.settings.cta_text }}
          </a>
        {% else %}
          <a href="#" class="ai-about-us-cta-button-{{ ai_gen_id }}">
            {{ block.settings.cta_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</about-us-{{ ai_gen_id }}>

<script>
  (function() {
    class AboutUs{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('about-us-{{ ai_gen_id }}', AboutUs{{ ai_gen_id }});
  })();
</script>


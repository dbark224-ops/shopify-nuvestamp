{% doc %}
  @prompt
    Create a high-impact final call-to-action section for a modern hair routine device brand.
    
    Headline: “Ready for Your New Hair Story?”
    
    Subheadline:
    “Take control of hair thinning, boost your confidence, and start seeing visible results for many users—right from home.”
    
    Button:
    “Shop Nuve Stamp Now”
    
    Design guidance:
    
    • Background: Use a Nuve brand accent (e.g., soft lilac #D6C8F5), large rounded container, centered content.
    • Text and button should contrast strongly (e.g., dark button on light background).
    • (Optional): Add a subtle product photo, hair routine icon, or trust badge (“30-Day Money-Back Guarantee”) just below the button.
    • Minimalist, modern, and high-conversion: focus attention on the CTA.
    The section should leave visitors feeling empowered and supported in taking action.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cta-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-cta-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-cta-headline-{{ ai_gen_id }} {
    color: {{ block.settings.headline_color }};
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.2;
    margin: 0;
    font-weight: 700;
  }

  .ai-cta-subheadline-{{ ai_gen_id }} {
    color: {{ block.settings.subheadline_color }};
    font-size: {{ block.settings.subheadline_size }}px;
    line-height: 1.5;
    margin: 0;
    max-width: {{ block.settings.subheadline_max_width }}px;
  }

  .ai-cta-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-cta-trust-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    color: {{ block.settings.trust_badge_color }};
    font-size: {{ block.settings.trust_badge_size }}px;
    font-weight: 500;
  }

  .ai-cta-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
  }

  .ai-cta-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-cta-product-image-{{ ai_gen_id }} {
    max-width: {{ block.settings.product_image_width }}px;
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.product_image_border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-cta-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-cta-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-cta-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.9 }}px;
    }

    .ai-cta-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.9 }}px {{ block.settings.button_padding_horizontal | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-cta-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cta-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-cta-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <div class="ai-cta-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-cta-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}

    {% if block.settings.show_product_image and block.settings.product_image %}
      <img
        src="{{ block.settings.product_image | image_url: width: 600 }}"
        alt="{{ block.settings.product_image.alt | escape }}"
        class="ai-cta-product-image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.product_image.width }}"
        height="{{ block.settings.product_image.height }}"
      >
    {% endif %}

    {% if block.settings.show_trust_badge %}
      <div class="ai-cta-trust-badge-{{ ai_gen_id }}">
        {% if block.settings.show_icon %}
          <div class="ai-cta-icon-{{ ai_gen_id }}">
            {% if block.settings.icon_type == 'checkmark' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
              </svg>
            {% elsif block.settings.icon_type == 'shield' %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/>
              </svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            {% endif %}
          </div>
        {% endif %}
        <span>{{ block.settings.trust_badge_text }}</span>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}

{% doc %}
  @prompt
    Create a persuasive section for a hair regrowth DTC brand.
    
    Headline: “Struggling with Hair Thinning or Shedding?”
    
    Subheadline: “You’re not alone. Millions face hair loss and thinning each year—but effective, science-backed solutions exist.”
    
    Body: Introduce the Nuve Stamp: an electric dermastamp with vibration and red light. Explain simply that it stimulates dormant hair follicles, supports new growth, and improves scalp health—all painlessly, at home, without drugs or doctor visits. Highlight emotional benefits such as restored confidence and control.
    
    CTA button: “How Nuve Stamp Works”
    
    Design:
    
    • Minimal, elegant, visually reassuring
    • Side-by-side photo: worried young adult (before) and a hopeful, growing-hair after photo, or iconographic illustration
    • Plenty of white space and brand color accents
    
    
    Let me know if you want prompts for other homepage sections!, can you make the before and after image just one image element, okay its good but the image is 1536 * 1024 so make it so it fits well with an image of that aspect ratio
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hair-regrowth-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_mobile }}px 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-hair-regrowth-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
      width: {{ block.settings.desktop_width_percent }}%;
      margin: 0 auto;
    }
  }

  .ai-hair-regrowth-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media screen and (min-width: 990px) {
    .ai-hair-regrowth-container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.layout }};
      align-items: center;
      gap: 60px;
    }
  }

  .ai-hair-regrowth-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-hair-regrowth-headline-{{ ai_gen_id }} {
    color: {{ block.settings.headline_color }};
    font-size: {{ block.settings.headline_size_mobile }}px;
    line-height: 1.2;
    margin: 0;
    font-weight: 700;
  }

  @media screen and (min-width: 750px) {
    .ai-hair-regrowth-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_desktop }}px;
    }
  }

  .ai-hair-regrowth-subheadline-{{ ai_gen_id }} {
    color: {{ block.settings.subheadline_color }};
    font-size: {{ block.settings.subheadline_size_mobile }}px;
    line-height: 1.5;
    margin: 0;
    font-weight: 500;
  }

  @media screen and (min-width: 750px) {
    .ai-hair-regrowth-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size_desktop }}px;
    }
  }

  .ai-hair-regrowth-body-{{ ai_gen_id }} {
    color: {{ block.settings.body_color }};
    font-size: {{ block.settings.body_size_mobile }}px;
    line-height: 1.7;
  }

  @media screen and (min-width: 750px) {
    .ai-hair-regrowth-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size_desktop }}px;
    }
  }

  .ai-hair-regrowth-body-{{ ai_gen_id }} p {
    margin: 0 0 16px 0;
  }

  .ai-hair-regrowth-body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-hair-regrowth-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .ai-hair-regrowth-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-hair-regrowth-image-container-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hair-regrowth-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: 600px;
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.image_shadow }};
  }

  .ai-hair-regrowth-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-hair-regrowth-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 3 / 2;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hair-regrowth-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-hair-regrowth-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<div
  class="ai-hair-regrowth-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-hair-regrowth-container-{{ ai_gen_id }}">
    <div class="ai-hair-regrowth-content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-hair-regrowth-headline-{{ ai_gen_id }}">
          {{ block.settings.headline }}
        </h2>
      {% endif %}

      {% if block.settings.subheadline != blank %}
        <p class="ai-hair-regrowth-subheadline-{{ ai_gen_id }}">
          {{ block.settings.subheadline }}
        </p>
      {% endif %}

      {% if block.settings.body_text != blank %}
        <div class="ai-hair-regrowth-body-{{ ai_gen_id }}">
          {{ block.settings.body_text }}
        </div>
      {% endif %}

      {% if block.settings.cta_text != blank %}
        <div>
          <a
            href="{{ block.settings.cta_link }}"
            class="ai-hair-regrowth-cta-{{ ai_gen_id }}"
          >
            {{ block.settings.cta_text }}
          </a>
        </div>
      {% endif %}
    </div>

    <div class="ai-hair-regrowth-image-container-{{ ai_gen_id }}">
      <div class="ai-hair-regrowth-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.comparison_image %}
          <img
            src="{{ block.settings.comparison_image | image_url: width: 1536 }}"
            alt="{{ block.settings.comparison_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.comparison_image.width }}"
            height="{{ block.settings.comparison_image.height }}"
            class="ai-hair-regrowth-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-hair-regrowth-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-hair-regrowth-empty-state-{{ ai_gen_id }}">
              Add before/after image
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>


{% doc %}
  @prompt
    Create an FAQ section for a premium hair regrowth device brand, Nuvé Stamp.
    
    Headline: “Frequently Asked Questions”
    
    Questions & Answers: (accordion or expandable style)
    
    1. How soon will I see new hair growth?
    Most users start seeing results—thicker, denser hair—within 3 to 6 weeks when using Nuvé Stamp weekly as directed.
    2. Does it hurt?
    No! The tiny needles and vibration make the experience comfortable. Most users describe it as a gentle tickle or tingling sensation.
    3. Who is Nuvé Stamp for?
    Nuvé Stamp is designed for adults experiencing mild to moderate hair thinning or loss. Safe for both men and women, and for all hair types.
    4. Can I use hair serums with Nuvé Stamp?
    Absolutely! Microneedling can help serums absorb more deeply and work better.
    5. How often should I use it?
    Use once per week on clean, dry scalp for optimal results.
    6. Is it safe for sensitive or color-treated scalps?
    Yes, just use gentle pressure and always follow the included instructions.
    • Design:  • Modern, easy to scan
      • Brand accent on questions or icons
      • Optionally add a “Still have questions? Contact us” CTA at the bottom
    
    Section should flow into your guarantee/support bar or final purchase CTA.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    display: block;
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-faq-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    background-color: {{ block.settings.item_background_color }};
    overflow: hidden;
    transition: all 0.2s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.item_hover_border_color }};
  }

  .ai-faq-question-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.question_padding }}px;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    color: {{ block.settings.question_color }};
    font-size: {{ block.settings.question_size }}px;
    font-weight: {{ block.settings.question_weight }};
    transition: color 0.2s ease;
  }

  .ai-faq-question-{{ ai_gen_id }}:hover {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
    color: {{ block.settings.accent_color }};
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
    max-height: 1000px;
    padding: 0 {{ block.settings.question_padding }}px {{ block.settings.question_padding }}px;
  }

  .ai-faq-answer-content-{{ ai_gen_id }} {
    color: {{ block.settings.answer_color }};
    font-size: {{ block.settings.answer_size }}px;
    line-height: 1.6;
  }

  .ai-faq-cta-{{ ai_gen_id }} {
    margin-top: {{ block.settings.cta_spacing }}px;
    text-align: {{ block.settings.cta_alignment }};
  }

  .ai-faq-cta-text-{{ ai_gen_id }} {
    color: {{ block.settings.cta_text_color }};
    font-size: {{ block.settings.cta_text_size }}px;
    margin-bottom: 16px;
  }

  .ai-faq-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.cta_button_padding }}px {{ block.settings.cta_button_padding | times: 2 }}px;
    background-color: {{ block.settings.cta_button_bg }};
    color: {{ block.settings.cta_button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_button_radius }}px;
    font-size: {{ block.settings.cta_button_size }}px;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .ai-faq-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_button_hover_bg }};
    color: {{ block.settings.cta_button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-faq-question-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_size | times: 0.9 }}px;
      padding: {{ block.settings.question_padding | times: 0.8 }}px;
    }

    .ai-faq-answer-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_size | times: 0.9 }}px;
    }

    .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.question_padding | times: 0.8 }}px {{ block.settings.question_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>

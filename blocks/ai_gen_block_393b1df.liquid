{% doc %}
  @prompt
    Create a high-impact final call-to-action section for a premium hair routine brand, Nuvé Stamp.
    
    Headline: “Ready to Upgrade Your Hair Routine?”
    
    Subheadline:
    “Take the first step toward thicker hair, stronger roots, and renewed self-belief—science-backed results, right from home.”
    
    Button:
    “Get Nuvé Stamp Now”
    
    Design notes:
    
    • Large, centered button with strong contrast (brand black background, white text, rounded corners)
    • Background: Soft lilac (#D6C8F5) or clean white with center accent, wide spacing
    • Below the button: Small trust text or badge (“30-Day Money-Back Guarantee”)
    • Minimal distractions—designed to convert
    Leave visitors feeling empowered, positive, and confident to make the purchase.
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cta-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 20px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-cta-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.content_spacing }}px;
  }

  .ai-cta-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-cta-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    color: {{ block.settings.subheadline_color }};
    margin: 0;
    line-height: 1.5;
    max-width: {{ block.settings.subheadline_max_width }}px;
  }

  .ai-cta-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: {{ block.settings.button_min_width }}px;
  }

  .ai-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  .ai-cta-trust-badge-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-size: {{ block.settings.trust_badge_size }}px;
    color: {{ block.settings.trust_badge_color }};
    margin-top: {{ block.settings.trust_badge_spacing }}px;
  }

  .ai-cta-trust-icon-{{ ai_gen_id }} {
    width: {{ block.settings.trust_badge_size }}px;
    height: {{ block.settings.trust_badge_size }}px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-cta-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.6 }}px 16px {{ block.settings.padding_bottom | times: 0.6 }}px;
    }

    .ai-cta-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-cta-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.9 }}px;
    }

    .ai-cta-button-{{ ai_gen_id }} {
      padding: {{ block.settings.button_padding_vertical | times: 0.9 }}px {{ block.settings.button_padding_horizontal | times: 0.9 }}px;
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-cta-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-cta-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-cta-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.subheadline != blank %}
      <div class="ai-cta-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-cta-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}

    {% if block.settings.show_trust_badge %}
      <div class="ai-cta-trust-badge-{{ ai_gen_id }}">
        <svg class="ai-cta-trust-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          <polyline points="9 12 11 14 15 10"></polyline>
        </svg>
        <span>{{ block.settings.trust_badge_text }}</span>
      </div>
    {% endif %}
  </div>
</div>


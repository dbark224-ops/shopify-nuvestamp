{% doc %}
  @prompt
    Add a feature grid highlighting the 3 key technologies of Nuvé Stamp.
    
    Blocks:
    
    • Microneedling: Creates tiny channels to wake up scalp activity.
    • Vibration Therapy: Comforts the scalp and maximizes serum absorption.
    • Red Light Therapy: Clinically studied light waves boost hair growth and scalp health.
    Clean icons, short description for each, accent color on icons/background.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tech-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-tech-grid__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-tech-grid__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.card_padding }}px;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-tech-grid__item-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-tech-grid__icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    background-color: {{ block.settings.icon_background }};
    border-radius: 50%;
    padding: {{ block.settings.icon_padding }}px;
  }

  .ai-tech-grid__icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    color: {{ block.settings.icon_color }};
  }

  .ai-tech-grid__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    line-height: 1.3;
  }

  .ai-tech-grid__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .ai-tech-grid__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-tech-grid__item-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.75 }}px;
    }

    .ai-tech-grid__icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-tech-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-tech-grid__container-{{ ai_gen_id }}">
    <div class="ai-tech-grid__item-{{ ai_gen_id }}">
      <div class="ai-tech-grid__icon-wrapper-{{ ai_gen_id }}">
        <svg class="ai-tech-grid__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="12" cy="5" r="1.5" fill="currentColor"/>
          <circle cx="12" cy="19" r="1.5" fill="currentColor"/>
          <circle cx="5" cy="12" r="1.5" fill="currentColor"/>
          <circle cx="19" cy="12" r="1.5" fill="currentColor"/>
          <circle cx="7.5" cy="7.5" r="1.5" fill="currentColor"/>
          <circle cx="16.5" cy="7.5" r="1.5" fill="currentColor"/>
          <circle cx="7.5" cy="16.5" r="1.5" fill="currentColor"/>
          <circle cx="16.5" cy="16.5" r="1.5" fill="currentColor"/>
        </svg>
      </div>
      <h3 class="ai-tech-grid__title-{{ ai_gen_id }}">{{ block.settings.tech_1_title }}</h3>
      <p class="ai-tech-grid__description-{{ ai_gen_id }}">{{ block.settings.tech_1_description }}</p>
    </div>

    <div class="ai-tech-grid__item-{{ ai_gen_id }}">
      <div class="ai-tech-grid__icon-wrapper-{{ ai_gen_id }}">
        <svg class="ai-tech-grid__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 3C12 3 8 6 8 12C8 18 12 21 12 21C12 21 16 18 16 12C16 6 12 3 12 3Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M12 8V16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
          <path d="M9 10L15 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M15 10L9 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <h3 class="ai-tech-grid__title-{{ ai_gen_id }}">{{ block.settings.tech_2_title }}</h3>
      <p class="ai-tech-grid__description-{{ ai_gen_id }}">{{ block.settings.tech_2_description }}</p>
    </div>

    <div class="ai-tech-grid__item-{{ ai_gen_id }}">
      <div class="ai-tech-grid__icon-wrapper-{{ ai_gen_id }}">
        <svg class="ai-tech-grid__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 4L13.5 8.5L18 10L13.5 11.5L12 16L10.5 11.5L6 10L10.5 8.5L12 4Z" fill="currentColor"/>
          <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
        </svg>
      </div>
      <h3 class="ai-tech-grid__title-{{ ai_gen_id }}">{{ block.settings.tech_3_title }}</h3>
      <p class="ai-tech-grid__description-{{ ai_gen_id }}">{{ block.settings.tech_3_description }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Technology features",
  "settings": [
    {
      "type": "header",
      "content": "Technology 1"
    },
    {
      "type": "text",
      "id": "tech_1_title",
      "label": "Title",
      "default": "Microneedling"
    },
    {
      "type": "textarea",
      "id": "tech_1_description",
      "label": "Description",
      "default": "Creates tiny channels to wake up scalp activity."
    },
    {
      "type": "header",
      "content": "Technology 2"
    },
    {
      "type": "text",
      "id": "tech_2_title",
      "label": "Title",
      "default": "Vibration Therapy"
    },
    {
      "type": "textarea",
      "id": "tech_2_description",
      "label": "Description",
      "default": "Comforts the scalp and maximizes serum absorption."
    },
    {
      "type": "header",
      "content": "Technology 3"
    },
    {
      "type": "text",
      "id": "tech_3_title",
      "label": "Title",
      "default": "Red Light Therapy"
    },
    {
      "type": "textarea",
      "id": "tech_3_description",
      "label": "Description",
      "default": "Clinically studied light waves boost hair growth and scalp health."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Gap between items",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Icon style"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "icon_padding",
      "label": "Icon padding",
      "min": 10,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "icon_background",
      "label": "Icon background",
      "default": "#d6c8f5"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#0b0b0d"
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Space below icon",
      "min": 10,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "title_spacing",
      "label": "Space below title",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Description size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#0b0b0d"
    }
  ],
  "presets": [
    {
      "name": "Technology features"
    }
  ]
}
{% endschema %}

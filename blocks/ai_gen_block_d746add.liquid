{% doc %}
  @prompt
    Include a “Best Results Tips” block:
    
    • Use 2–3x per week, on clean/dry scalp
    • Always start with the lowest setting
    • Pair with your favorite growth serum or oil
    • Take before photos to track your progress!
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tips-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-tips-block__header-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-tips-block__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.tip_spacing }}px;
  }

  .ai-tips-block__item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_spacing }}px;
  }

  .ai-tips-block__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  .ai-tips-block__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ block.settings.icon_color }};
    stroke-width: 2;
  }

  .ai-tips-block__text-{{ ai_gen_id }} {
    flex: 1;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-tips-block-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-tips-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h3 class="ai-tips-block__header-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  {% endif %}

  <ul class="ai-tips-block__list-{{ ai_gen_id }}">
    {% if block.settings.tip_1 != blank %}
      <li class="ai-tips-block__item-{{ ai_gen_id }}">
        <div class="ai-tips-block__icon-{{ ai_gen_id }}">
          {% if block.settings.icon_style == 'checkmark' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {% elsif block.settings.icon_style == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% elsif block.settings.icon_style == 'circle' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"></circle>
            </svg>
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="2" fill="{{ block.settings.icon_color }}"></circle>
            </svg>
          {% endif %}
        </div>
        <div class="ai-tips-block__text-{{ ai_gen_id }}">{{ block.settings.tip_1 }}</div>
      </li>
    {% endif %}

    {% if block.settings.tip_2 != blank %}
      <li class="ai-tips-block__item-{{ ai_gen_id }}">
        <div class="ai-tips-block__icon-{{ ai_gen_id }}">
          {% if block.settings.icon_style == 'checkmark' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {% elsif block.settings.icon_style == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% elsif block.settings.icon_style == 'circle' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"></circle>
            </svg>
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="2" fill="{{ block.settings.icon_color }}"></circle>
            </svg>
          {% endif %}
        </div>
        <div class="ai-tips-block__text-{{ ai_gen_id }}">{{ block.settings.tip_2 }}</div>
      </li>
    {% endif %}

    {% if block.settings.tip_3 != blank %}
      <li class="ai-tips-block__item-{{ ai_gen_id }}">
        <div class="ai-tips-block__icon-{{ ai_gen_id }}">
          {% if block.settings.icon_style == 'checkmark' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {% elsif block.settings.icon_style == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% elsif block.settings.icon_style == 'circle' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"></circle>
            </svg>
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="2" fill="{{ block.settings.icon_color }}"></circle>
            </svg>
          {% endif %}
        </div>
        <div class="ai-tips-block__text-{{ ai_gen_id }}">{{ block.settings.tip_3 }}</div>
      </li>
    {% endif %}

    {% if block.settings.tip_4 != blank %}
      <li class="ai-tips-block__item-{{ ai_gen_id }}">
        <div class="ai-tips-block__icon-{{ ai_gen_id }}">
          {% if block.settings.icon_style == 'checkmark' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {% elsif block.settings.icon_style == 'star' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
            </svg>
          {% elsif block.settings.icon_style == 'circle' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10"></circle>
            </svg>
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="2" fill="{{ block.settings.icon_color }}"></circle>
            </svg>
          {% endif %}
        </div>
        <div class="ai-tips-block__text-{{ ai_gen_id }}">{{ block.settings.tip_4 }}</div>
      </li>
    {% endif %}
  </ul>
</div>

{% schema %}
{
  "name": "Best results tips",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Best Results Tips"
    },
    {
      "type": "textarea",
      "id": "tip_1",
      "label": "Tip 1",
      "default": "Use 2–3x per week, on clean/dry scalp"
    },
    {
      "type": "textarea",
      "id": "tip_2",
      "label": "Tip 2",
      "default": "Always start with the lowest setting"
    },
    {
      "type": "textarea",
      "id": "tip_3",
      "label": "Tip 3",
      "default": "Pair with your favorite growth serum or oil"
    },
    {
      "type": "textarea",
      "id": "tip_4",
      "label": "Tip 4",
      "default": "Take before photos to track your progress!"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Heading spacing",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "tip_spacing",
      "label": "Tip spacing",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon style",
      "options": [
        {
          "value": "checkmark",
          "label": "Checkmark"
        },
        {
          "value": "star",
          "label": "Star"
        },
        {
          "value": "circle",
          "label": "Circle"
        },
        {
          "value": "dot",
          "label": "Dot"
        }
      ],
      "default": "checkmark"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_spacing",
      "label": "Icon spacing",
      "min": 5,
      "max": 25,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#0b0b0d"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3f3f4"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#0b0b0d"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#0b0b0d"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Best results tips"
    }
  ]
}
{% endschema %}
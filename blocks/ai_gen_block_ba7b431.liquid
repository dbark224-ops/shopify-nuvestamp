{% doc %}
  @prompt
    Create a visual, easy-to-follow 4-step sequence for a hair routine device brand, Nuvé Stamp.
    
    Steps:
    
    1. Prep Your Scalp: Cleanse and part your hair.
    2. Activate Device: Select micro-needling, vibration, and red light modes.
    3. Gently Stamp: Move Nuvé Stamp over thinning areas—vibration soothes, red light stimulates follicles.
    4. Apply Serum: Massage in your favorite serum for deeper absorption and fast results.
    Design: Modern icon for each step, numbered, with a brief description. Use brand accent colors and plenty of white space.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-step-sequence-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-step-sequence__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-step-sequence__heading-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-step-sequence__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.step_spacing }}px;
  }

  .ai-step-sequence__step-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.step_padding }}px;
    background-color: {{ block.settings.step_background_color }};
    border-radius: {{ block.settings.step_border_radius }}px;
  }

  .ai-step-sequence__icon-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background_color }};
    border-radius: 50%;
  }

  .ai-step-sequence__number-{{ ai_gen_id }} {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 32px;
    height: 32px;
    background-color: {{ block.settings.number_background_color }};
    color: {{ block.settings.number_text_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 14px;
  }

  .ai-step-sequence__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size | times: 0.6 }}px;
    height: {{ block.settings.icon_size | times: 0.6 }}px;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 2;
  }

  .ai-step-sequence__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin-bottom: {{ block.settings.title_spacing }}px;
  }

  .ai-step-sequence__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 989px) {
    .ai-step-sequence__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-step-sequence__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.step_spacing | times: 0.8 }}px;
    }

    .ai-step-sequence__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-step-sequence__icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-step-sequence__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.5 }}px;
      height: {{ block.settings.icon_size | times: 0.5 }}px;
    }
  }
{% endstyle %}

<nuve-step-sequence-{{ ai_gen_id }} class="ai-step-sequence-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-step-sequence__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-step-sequence__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-step-sequence__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign step_enabled_key = 'step_' | append: i | append: '_enabled'
          assign step_title_key = 'step_' | append: i | append: '_title'
          assign step_description_key = 'step_' | append: i | append: '_description'

          assign step_enabled = block.settings[step_enabled_key]
          assign step_title = block.settings[step_title_key]
          assign step_description = block.settings[step_description_key]
        %}

        {% if step_enabled %}
          <div class="ai-step-sequence__step-{{ ai_gen_id }}">
            <div class="ai-step-sequence__icon-wrapper-{{ ai_gen_id }}">
              <div class="ai-step-sequence__number-{{ ai_gen_id }}">{{ i }}</div>
              
              {% case i %}
                {% when 1 %}
                  <svg class="ai-step-sequence__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                    <path d="M12 6c-3.31 0-6 2.69-6 6h2c0-2.21 1.79-4 4-4s4 1.79 4 4-1.79 4-4 4v2c3.31 0 6-2.69 6-6s-2.69-6-6-6z"/>
                  </svg>
                {% when 2 %}
                  <svg class="ai-step-sequence__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M12 6v6l4 2"/>
                  </svg>
                {% when 3 %}
                  <svg class="ai-step-sequence__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                    <path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                  </svg>
                {% when 4 %}
                  <svg class="ai-step-sequence__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                  </svg>
              {% endcase %}
            </div>

            {% if step_title != blank %}
              <h3 class="ai-step-sequence__title-{{ ai_gen_id }}">{{ step_title }}</h3>
            {% endif %}

            {% if step_description != blank %}
              <p class="ai-step-sequence__description-{{ ai_gen_id }}">{{ step_description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</nuve-step-sequence-{{ ai_gen_id }}>

<script>
  (function() {
    class NuveStepSequence{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initializeObserver();
      }

      initializeObserver() {
        const steps = this.querySelectorAll('.ai-step-sequence__step-{{ ai_gen_id }}');
        
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }
            });
          }, {
            threshold: 0.1
          });

          steps.forEach((step, index) => {
            step.style.opacity = '0';
            step.style.transform = 'translateY(20px)';
            step.style.transition = `opacity 0.6s ease ${index * 0.1}s, transform 0.6s ease ${index * 0.1}s`;
            observer.observe(step);
          });
        }
      }
    }

    customElements.define('nuve-step-sequence-{{ ai_gen_id }}', NuveStepSequence{{ ai_gen_id }});
  })();
</script>


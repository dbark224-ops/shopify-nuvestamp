{% doc %}
  @prompt
    Create a conversion-focused “Problem/Solution” section for a DTC hair regrowth brand (Nuvé Stamp).
    
    Headline: “Losing Hair Doesn’t Mean Losing Hope”
    
    Body Copy:
    “Thinning hair, widening parts, or an ever-visible scalp—it’s an experience no one wants, and it affects men and women of all ages. But you don’t need to settle for hopelessness or dependency on harsh chemicals.
    
    Nuvé Stamp gives you a modern, science-backed solution: our electric dermastamp with red light and vibration technology stimulates dormant hair follicles and brings new growth back within your control—right at home, painlessly and safely.”
    
    Emotional hook:
    “Regain your confidence. Rediscover your best hair—no clinic visits, no prescriptions.”
    
    Design:
    
    • Minimal, modern, brand-aligned
    • Light background, subtle accent border or shadow
    • CTA button: “See How Nuvé Stamp Changes Hair Regrowth” (link to How It Works or scrolls to next section)
    Visual: If image/icon is included, show outline of a hopeful person looking in the mirror with thicker hair, or a closeup of scalp transitioning from sparse to fuller.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-problem-solution-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    {% if block.settings.show_border %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
    {% if block.settings.show_shadow %}
      box-shadow: 0 {{ block.settings.shadow_offset_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    {% endif %}
  }

  .ai-problem-solution-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-problem-solution-headline-{{ ai_gen_id }} {
    color: {{ block.settings.headline_color }};
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.2;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    font-weight: 700;
  }

  .ai-problem-solution-body-{{ ai_gen_id }} {
    color: {{ block.settings.body_color }};
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.6;
    margin: 0 0 {{ block.settings.body_spacing }}px;
  }

  .ai-problem-solution-body-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
  }

  .ai-problem-solution-body-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-problem-solution-hook-{{ ai_gen_id }} {
    color: {{ block.settings.hook_color }};
    font-size: {{ block.settings.hook_size }}px;
    line-height: 1.4;
    margin: 0 0 {{ block.settings.hook_spacing }}px;
    font-weight: 600;
    font-style: italic;
  }

  .ai-problem-solution-cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-problem-solution-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-problem-solution-visual-{{ ai_gen_id }} {
    margin: {{ block.settings.visual_spacing }}px 0 0;
    display: flex;
    justify-content: center;
  }

  .ai-problem-solution-visual-{{ ai_gen_id }} img {
    max-width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-problem-solution-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
  }

  .ai-problem-solution-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-problem-solution-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-problem-solution-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-problem-solution-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-problem-solution-hook-{{ ai_gen_id }} {
      font-size: {{ block.settings.hook_size | times: 0.85 }}px;
    }

    .ai-problem-solution-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_padding_vertical | times: 0.85 }}px {{ block.settings.button_padding_horizontal | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-problem-solution-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-problem-solution-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-problem-solution-headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h2>
    {% endif %}

    {% if block.settings.body_copy != blank %}
      <div class="ai-problem-solution-body-{{ ai_gen_id }}">
        {{ block.settings.body_copy }}
      </div>
    {% endif %}

    {% if block.settings.emotional_hook != blank %}
      <div class="ai-problem-solution-hook-{{ ai_gen_id }}">
        {{ block.settings.emotional_hook }}
      </div>
    {% endif %}

    {% if block.settings.cta_text != blank %}
      <a
        href="{{ block.settings.cta_link }}"
        class="ai-problem-solution-cta-{{ ai_gen_id }}"
      >
        {{ block.settings.cta_text }}
      </a>
    {% endif %}

    {% if block.settings.show_visual %}
      <div class="ai-problem-solution-visual-{{ ai_gen_id }}">
        {% if block.settings.visual_image %}
          <img
            src="{{ block.settings.visual_image | image_url: width: 800 }}"
            alt="{{ block.settings.visual_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.visual_image.width }}"
            height="{{ block.settings.visual_image.height }}"
          >
        {% else %}
          <div class="ai-problem-solution-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>


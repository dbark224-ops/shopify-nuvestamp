{% doc %}
  @prompt
    Headline:
    Unleash Smoother, Healthier Skin at Home
    
    Subheadline:
    The original electric dermastamp with vibration and red light therapy—scientifically-designed for visible results for many users.
    
    CTA Button:
    Shop Nuve Stamp
    
    Product visual:
    (Insert high-res product image/video or a lifestyle shot)
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-hero-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    line-height: 1.2;
    color: {{ block.settings.headline_color }};
    margin: 0;
  }

  .ai-hero-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    line-height: 1.5;
    color: {{ block.settings.subheadline_color }};
    margin: 0;
  }

  .ai-hero-cta-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    align-self: flex-start;
  }

  .ai-hero-cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-hero-media-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_max_width }}px;
  }

  .ai-hero-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-container-{{ ai_gen_id }} {
      flex-direction: column;
      text-align: center;
      padding: {{ block.settings.padding_vertical | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-hero-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.9 }}px;
    }

    .ai-hero-cta-{{ ai_gen_id }} {
      align-self: center;
    }

    .ai-hero-media-{{ ai_gen_id }} {
      order: -1;
    }
  }
{% endstyle %}

<div class="ai-hero-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-container-{{ ai_gen_id }}">
    <div class="ai-hero-content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
      {% endif %}

      {% if block.settings.subheadline != blank %}
        <p class="ai-hero-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
      {% endif %}

      {% if block.settings.cta_text != blank %}
        <a href="{{ block.settings.cta_link }}" class="ai-hero-cta-{{ ai_gen_id }}">
          {{ block.settings.cta_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-hero-media-{{ ai_gen_id }}">
      <div class="ai-hero-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1000 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
            class="ai-hero-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-hero-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
            <div class="ai-hero-empty-state-{{ ai_gen_id }}">
              Next, add a product image
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>


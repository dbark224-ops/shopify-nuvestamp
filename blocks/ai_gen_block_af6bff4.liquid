{% doc %}
  @prompt
    Create a trust and guarantee bar for a premium hair regrowth device brand (Nuvé Stamp).
    
    Content to include:
    
    • “30-Day See New Growth Guarantee”
    • “Free Tracked Shipping Worldwide”
    • “Safe Checkout—Visa • Mastercard • PayPal”
    Design guidance:
    
    • Horizontal bar (or stacked on mobile), high-contrast, bold and easy to spot
    • Optionally add a shield icon, checkmark, or badge
    • Brand-aligned color (soft lilac #D6C8F5 or off-white #F3F3F4 background, near-black text/icons)
    • Subtle divider or box shadow for prominence
    Place this just above your final purchase CTA and/or sticky add-to-cart button to reinforce buyer confidence.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-bar-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-trust-bar-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.item_spacing }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    {% if block.settings.show_shadow %}
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    {% endif %}
    {% if block.settings.show_border %}
      border: 1px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-trust-bar-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    flex: 1;
    justify-content: center;
    min-width: 0;
  }

  .ai-trust-bar-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-trust-bar-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-trust-bar-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.3;
    text-align: left;
  }

  .ai-trust-bar-divider-{{ ai_gen_id }} {
    width: 1px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-bar-container-{{ ai_gen_id }} {
      flex-direction: {{ block.settings.mobile_layout }};
      gap: {{ block.settings.mobile_item_spacing }}px;
      padding: {{ block.settings.mobile_padding_vertical }}px {{ block.settings.mobile_padding_horizontal }}px;
    }

    .ai-trust-bar-item-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        justify-content: flex-start;
      {% endif %}
    }

    .ai-trust-bar-divider-{{ ai_gen_id }} {
      {% if block.settings.mobile_layout == 'column' %}
        width: 100%;
        height: 1px;
      {% endif %}
    }

    .ai-trust-bar-icon-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_icon_size }}px;
      height: {{ block.settings.mobile_icon_size }}px;
    }

    .ai-trust-bar-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-bar-container-{{ ai_gen_id }}">
    {% if block.settings.show_item_1 %}
      <div class="ai-trust-bar-item-{{ ai_gen_id }}">
        <div class="ai-trust-bar-icon-{{ ai_gen_id }}">
          {% if block.settings.icon_1 == 'shield' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          {% elsif block.settings.icon_1 == 'check' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {% elsif block.settings.icon_1 == 'badge' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="7"></circle>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
            </svg>
          {% endif %}
        </div>
        <div class="ai-trust-bar-text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_item_1 and block.settings.show_item_2 and block.settings.show_dividers %}
      <div class="ai-trust-bar-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.show_item_2 %}
      <div class="ai-trust-bar-item-{{ ai_gen_id }}">
        <div class="ai-trust-bar-icon-{{ ai_gen_id }}">
          {% if block.settings.icon_2 == 'shield' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          {% elsif block.settings.icon_2 == 'check' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {% elsif block.settings.icon_2 == 'badge' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="7"></circle>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
            </svg>
          {% elsif block.settings.icon_2 == 'truck' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13"></rect>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
              <circle cx="5.5" cy="18.5" r="2.5"></circle>
              <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
          {% endif %}
        </div>
        <div class="ai-trust-bar-text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</div>
      </div>
    {% endif %}

    {% if block.settings.show_item_2 and block.settings.show_item_3 and block.settings.show_dividers %}
      <div class="ai-trust-bar-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.show_item_3 %}
      <div class="ai-trust-bar-item-{{ ai_gen_id }}">
        <div class="ai-trust-bar-icon-{{ ai_gen_id }}">
          {% if block.settings.icon_3 == 'shield' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          {% elsif block.settings.icon_3 == 'check' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          {% elsif block.settings.icon_3 == 'badge' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="7"></circle>
              <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
            </svg>
          {% elsif block.settings.icon_3 == 'lock' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          {% endif %}
        </div>
        <div class="ai-trust-bar-text-{{ ai_gen_id }}">{{ block.settings.text_3 }}</div>
      </div>
    {% endif %}
  </div>
</div>


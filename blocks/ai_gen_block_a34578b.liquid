{% doc %}
  @prompt
    Create an FAQ section for a premium hair routine device brand.
    
    Headline: “Frequently Asked Questions”
    
    Questions & Answers: (accordion or expandable style)
    
    1. How soon will I see results?
    Most users notice improvement in hair thickness and density within 8–12 weeks when using Nuve Stamp as directed.
    2. Does it hurt?
    No, the micro-needles are ultra-fine and combined with soothing vibration. Most users describe it as a gentle tingling feeling—not painful.
    3. Who can use Nuve Stamp?
    Nuve Stamp is safe for adult men and women with thinning hair or mild–moderate hair thinning. If you have a medical condition, consult your doctor first.
    4. Can I use growth serums with Nuve Stamp?
    Absolutely! In fact, the device helps increase absorption and effectiveness of most topical hair serums.
    5. How often should I use it?
    For best results, use Nuve Stamp 2–3x per week on clean, dry scalp.
    6. Is it safe for color-treated or sensitive scalps?
    Yes. Start gently and always follow the included instructions for your skin and hair type.
    • Design:
    Clean, modern, easily scannable. Brand colors for question emphasis. Optionally, small CTA at bottom: “See Full FAQ” or “Still have questions? Contact Us!”
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-faq-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-faq-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_spacing }}px;
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    font-weight: 700;
  }

  .ai-faq-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    background-color: {{ block.settings.item_background_color }};
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.item_border_hover_color }};
  }

  .ai-faq-question-button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.question_padding }}px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 16px;
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_size }}px;
    color: {{ block.settings.question_color }};
    font-weight: 600;
    margin: 0;
    flex: 1;
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-faq-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    stroke-width: 2;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-answer-wrapper-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.question_padding }}px {{ block.settings.question_padding }}px;
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
  }

  .ai-faq-cta-{{ ai_gen_id }} {
    margin-top: {{ block.settings.cta_spacing }}px;
    text-align: {{ block.settings.cta_alignment }};
  }

  .ai-faq-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.cta_button_padding }}px {{ block.settings.cta_button_padding | times: 2 }}px;
    background-color: {{ block.settings.cta_button_bg }};
    color: {{ block.settings.cta_button_text }};
    text-decoration: none;
    border-radius: {{ block.settings.cta_button_radius }}px;
    font-size: {{ block.settings.cta_button_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .ai-faq-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.cta_button_bg_hover }};
    color: {{ block.settings.cta_button_text_hover }};
  }

  @media screen and (max-width: 749px) {
    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-faq-question-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_size | times: 0.9 }}px;
    }

    .ai-faq-answer-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_size | times: 0.9 }}px;
    }

    .ai-faq-question-button-{{ ai_gen_id }} {
      padding: {{ block.settings.question_padding | times: 0.8 }}px;
    }

    .ai-faq-answer-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.question_padding | times: 0.8 }}px {{ block.settings.question_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-faq-header-{{ ai_gen_id }}">
        <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="ai-faq-list-{{ ai_gen_id }}">
      {% if block.settings.faq_1_question != blank %}
        <div class="ai-faq-item-{{ ai_gen_id }}" data-faq-item>
          <button class="ai-faq-question-button-{{ ai_gen_id }}" aria-expanded="false">
            <h3 class="ai-faq-question-text-{{ ai_gen_id }}">{{ block.settings.faq_1_question }}</h3>
            <span class="ai-faq-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </button>
          <div class="ai-faq-answer-wrapper-{{ ai_gen_id }}">
            <div class="ai-faq-answer-{{ ai_gen_id }}">{{ block.settings.faq_1_answer }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.faq_2_question != blank %}
        <div class="ai-faq-item-{{ ai_gen_id }}" data-faq-item>
          <button class="ai-faq-question-button-{{ ai_gen_id }}" aria-expanded="false">
            <h3 class="ai-faq-question-text-{{ ai_gen_id }}">{{ block.settings.faq_2_question }}</h3>
            <span class="ai-faq-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </button>
          <div class="ai-faq-answer-wrapper-{{ ai_gen_id }}">
            <div class="ai-faq-answer-{{ ai_gen_id }}">{{ block.settings.faq_2_answer }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.faq_3_question != blank %}
        <div class="ai-faq-item-{{ ai_gen_id }}" data-faq-item>
          <button class="ai-faq-question-button-{{ ai_gen_id }}" aria-expanded="false">
            <h3 class="ai-faq-question-text-{{ ai_gen_id }}">{{ block.settings.faq_3_question }}</h3>
            <span class="ai-faq-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </button>
          <div class="ai-faq-answer-wrapper-{{ ai_gen_id }}">

{% doc %}
  @prompt
    Create a science-backed “How It Works” section for a premium hair routine brand, Nuvé Stamp.
    
    Headline: “How Nuvé Stamp Supports Your Hair Routine”
    
    Subheadline: “3 Proven Technologies. 1 Simple Routine.”
    
    Present these as horizontal steps or feature blocks, each with an icon or simple graphic:
    
    1. Microneedling
    “Tiny precision needles create micro-channels in the scalp, triggering your body’s natural growth response and maximizing serum absorption.”
    2. Vibration Therapy
    “Soothes the scalp, enhances comfort, and helps drive growth factors deeper—no pain, no fuss.”
    3. Red Light Therapy
    “Stimulates hair follicles at a cellular level, boosting growth and supporting thick, healthy thickness support—clinically studied wavelengths included.”
    Footer statement:
    “Use Nuvé Stamp just 2–3x per week and start noticing stronger, fuller hair in around 8–12 weeks.”
    
    Design:
    
    • Modern, scientific, clean (brand lilac accent backgrounds or icons)
    • Each technology pillar gets a matching visual/icon
    • Optional: Add a “Learn more about our science” text link/button or scroll cue
    Section should smoothly transition into real user results/testimonials.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-how-it-works-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-how-it-works-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-how-it-works-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-how-it-works-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    line-height: 1.2;
  }

  .ai-how-it-works-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheadline_size }}px;
    font-weight: 500;
    color: {{ block.settings.subheadline_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-how-it-works-steps-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: {{ block.settings.step_gap }}px;
    margin-bottom: {{ block.settings.footer_spacing }}px;
  }

  .ai-how-it-works-step-{{ ai_gen_id }} {
    background-color: {{ block.settings.step_background_color }};
    border-radius: {{ block.settings.step_border_radius }}px;
    padding: {{ block.settings.step_padding }}px;
    text-align: center;
    transition: transform 0.2s ease;
  }

  .ai-how-it-works-step-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-how-it-works-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    background-color: {{ block.settings.icon_background_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-how-it-works-icon-{{ ai_gen_id }} {
    width: calc({{ block.settings.icon_size }}px * 0.5);
    height: calc({{ block.settings.icon_size }}px * 0.5);
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-how-it-works-step-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_title_size }}px;
    font-weight: 700;
    color: {{ block.settings.step_title_color }};
    margin: 0 0 {{ block.settings.step_title_spacing }}px;
    line-height: 1.3;
  }

  .ai-how-it-works-step-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_description_size }}px;
    color: {{ block.settings.step_description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-how-it-works-footer-{{ ai_gen_id }} {
    text-align: center;
    padding-top: {{ block.settings.footer_spacing }}px;
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-how-it-works-footer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.footer_text_size }}px;
    color: {{ block.settings.footer_text_color }};
    margin: 0 0 {{ block.settings.footer_link_spacing }}px;
    line-height: 1.6;
    font-weight: 500;
  }

  .ai-how-it-works-footer-link-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.footer_link_size }}px;
    color: {{ block.settings.footer_link_color }};
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .ai-how-it-works-footer-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.footer_link_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-how-it-works-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 16px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-how-it-works-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-how-it-works-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheadline_size | times: 0.85 }}px;
    }

    .ai-how-it-works-steps-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.step_gap | times: 0.75 }}px;
    }

    .ai-how-it-works-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }

    .ai-how-it-works-icon-{{ ai_gen_id }} {
      width: calc({{ block.settings.icon_size | times: 0.85 }}px * 0.5);
      height: calc({{ block.settings.icon_size | times: 0.85 }}px * 0.5);
    }
  }
{% endstyle %}

<div class="ai-how-it-works-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-how-it-works-container-{{ ai_gen_id }}">
    <div class="ai-how-it-works-header-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-how-it-works-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
      {% endif %}
      {% if block.settings.subheadline != blank %}
        <p class="ai-how-it-works-subheadline-{{ ai_gen_id }}">{{ block.settings.subheadline }}</p>
      {% endif %}
    </div>

    <div class="ai-how-it-works-steps-{{ ai_gen_id }}">
      <div class="ai-how-it-works-step-{{ ai_gen_id }}">
        <div class="ai-how-it-works-icon-wrapper-{{ ai_gen_id }}">
          <svg class="ai-how-it-works-icon-{{ ai_gen_id }}" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="12" cy="12" r="6"></circle>
            <circle cx="12" cy="12" r="2"></circle>
            <line x1="12" y1="2" x2="12" y2="6"></line>
            <line x1="12" y1="18" x2="12" y2="22"></line>
            <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line>
            <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line>
            <line x1="2" y1="12" x2="6" y2="12"></line>
            <line x1="18" y1="12" x2="22" y2="12"></line>
            <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line>
            <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line>
          </svg>
        </div>
        <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_1_title }}</h3>
        <p class="ai-how-it-works-step-description-{{ ai_gen_id }}">{{ block.settings.step_1_description }}</p>
      </div>

      <div class="ai-how-it-works-step-{{ ai_gen_id }}">
        <div class="ai-how-it-works-icon-wrapper-{{ ai_gen_id }}">
          <svg class="ai-how-it-works-icon-{{ ai_gen_id }}" viewBox="0 0 24 24">
            <path d="M12 2v20"></path>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
            <circle cx="12" cy="12" r="1"></circle>
            <circle cx="12" cy="8" r="1"></circle>
            <circle cx="12" cy="16" r="1"></circle>
          </svg>
        </div>
        <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_2_title }}</h3>
        <p class="ai-how-it-works-step-description-{{ ai_gen_id }}">{{ block.settings.step_2_description }}</p>
      </div>

      <div class="ai-how-it-works-step-{{ ai_gen_id }}">
        <div class="ai-how-it-works-icon-wrapper-{{ ai_gen_id }}">
          <svg class="ai-how-it-works-icon-{{ ai_gen_id }}" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
        </div>
        <h3 class="ai-how-it-works-step-title-{{ ai_gen_id }}">{{ block.settings.step_3_title }}</h3>
        <p class="ai-how-it-works-step-description-{{ ai_gen_id }}">{{ block.settings.step_3_description }}</p>
      </div>
    </div>

    <div class="ai-how-it-works-footer-{{ ai_gen_id }}">
      {% if block.settings.footer_text != blank %}
        <p class="ai-how-it-works-footer-text-{{ ai_gen_id }}">{{ block.settings.footer_text }}</p>
      {% endif %}
      {% if block.settings.show_footer_link and block.settings.footer_link_text != blank %}
        <a href="{{ block.settings.footer_link_url }}" class="ai-how-it-works-footer-link-{{ ai_gen_id }}">
          {{ block.settings.footer_link_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>


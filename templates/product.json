              "disabled": true,
              "settings": {
                "custom_liquid": "<div id=\"buy\" style=\"position: relative; top: -90px;\"></div>\n\n{%- comment -%} Mobile-only Quick CTA + Trust Strip + Price {%- endcomment -%}\n\n{%- assign btn_text = 'Get Nuvé Stamp Now' -%}\n{%- assign trust_left = '30-Day Money-Back Guarantee' -%}\n{%- assign trust_right = 'Free Shipping' -%}\n{%- assign rating_text = '5/5' -%}\n{%- assign rating_sub = 'Trusted by 5,000+ customers' -%}\n\n{%- assign v = product.selected_or_first_available_variant -%}\n{%- assign price = v.price -%}\n{%- assign compare_at = v.compare_at_price -%}\n\n{%- assign has_discount = false -%}\n{%- if compare_at and compare_at > price -%}\n  {%- assign has_discount = true -%}\n  {%- assign discount_amount = compare_at | minus: price -%}\n  {%- assign discount_pct = discount_amount | times: 100 | divided_by: compare_at -%}\n{%- endif -%}\n\n<style>\n  .nuve-mobile-quick{\n    display: block;\n    margin: 14px 16px 0;\n    padding: 14px 14px;\n    border-radius: 16px;\n    background: rgba(201,183,255,0.22);\n    border: 1px solid rgba(201,183,255,0.45);\n  }\n\n  .nuve-mq-top{\n    display:flex;\n    align-items:center;\n    justify-content:space-between;\n    gap: 10px;\n    margin-bottom: 10px;\n  }\n\n  .nuve-mq-stars{\n    display:flex;\n    align-items:center;\n    gap: 8px;\n    line-height: 1;\n  }\n  .nuve-mq-stars .stars{\n    display:flex;\n    gap: 3px;\n  }\n  .nuve-mq-stars svg{\n    width: 14px;\n    height: 14px;\n    fill: #F5A623;\n    display:block;\n  }\n  .nuve-mq-rating{\n    font-size: 13px;\n    font-weight: 800;\n    color:#111;\n    white-space: nowrap;\n  }\n\n  /* Price row */\n  .nuve-mq-price{\n    display:flex;\n    align-items: baseline;\n    justify-content: space-between;\n    gap: 12px;\n    margin: 6px 0 10px;\n  }\n  .nuve-mq-price-left{\n    display:flex;\n    align-items: baseline;\n    gap: 10px;\n    flex-wrap: wrap;\n  }\n  .nuve-mq-price-now{\n    font-size: 18px;\n    font-weight: 900;\n    color:#111;\n    letter-spacing: -0.01em;\n  }\n  .nuve-mq-price-was{\n    font-size: 13px;\n    font-weight: 800;\n    color: rgba(17,17,17,0.55);\n    text-decoration: line-through;\n  }\n  .nuve-mq-badge{\n    font-size: 12px;\n    font-weight: 900;\n    color: #111;\n    background: rgba(255,255,255,0.65);\n    border: 1px solid rgba(17,17,17,0.10);\n    padding: 6px 10px;\n    border-radius: 9999px;\n    white-space: nowrap;\n  }\n\n  .nuve-mq-sub{\n    font-size: 12px;\n    font-weight: 600;\n    color: rgba(17,17,17,0.75);\n    margin: 0 0 12px;\n  }\n\n  .nuve-mq-btn{\n    width: 100%;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    padding: 14px 16px;\n    border-radius: 9999px;\n    background:#111;\n    color:#fff;\n    text-decoration:none;\n    font-size: 14px;\n    font-weight: 900;\n    line-height: 1;\n    box-shadow: 0 12px 26px rgba(0,0,0,0.18);\n    transition: transform .14s ease, box-shadow .14s ease, opacity .14s ease;\n  }\n  .nuve-mq-btn:active{ opacity:.92; transform: translateY(0); }\n\n  .nuve-mq-trust{\n    display:flex;\n    justify-content:center;\n    gap: 14px;\n    margin-top: 10px;\n    flex-wrap: wrap;\n    font-size: 12px;\n    font-weight: 700;\n    color: rgba(17,17,17,0.75);\n  }\n  .nuve-mq-trust span{\n    display:inline-flex;\n    align-items:center;\n    gap: 7px;\n    white-space: nowrap;\n  }\n  .nuve-mq-trust svg{\n    width: 16px;\n    height: 16px;\n    stroke: rgba(17,17,17,0.75);\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* Mobile only */\n  @media (min-width: 750px){\n    .nuve-mobile-quick{ display:none; }\n  }\n</style>\n\n<div class=\"nuve-mobile-quick\">\n  <div class=\"nuve-mq-top\">\n    <div class=\"nuve-mq-stars\" aria-label=\"Rating {{ rating_text }}\">\n      <span class=\"stars\" aria-hidden=\"true\">\n        {% for i in (1..5) %}\n          <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n        {% endfor %}\n      </span>\n      <span class=\"nuve-mq-rating\">{{ rating_text }}</span>\n    </div>\n  </div>\n\n  <p class=\"nuve-mq-sub\">{{ rating_sub }}</p>\n\n  <div class=\"nuve-mq-price\" aria-label=\"Price\">\n    <div class=\"nuve-mq-price-left\">\n      <span class=\"nuve-mq-price-now\">{{ price | money }}</span>\n\n      {% if has_discount %}\n        <span class=\"nuve-mq-price-was\">{{ compare_at | money }}</span>\n        <span class=\"nuve-mq-badge\">{{ discount_pct }}% OFF</span>\n      {% endif %}\n    </div>\n  </div>\n\n  <a class=\"nuve-mq-btn\" href=\"#buy\">{{ btn_text }}</a>\n\n  <div class=\"nuve-mq-trust\" role=\"list\">\n    <span role=\"listitem\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 2l8 4v6c0 5-3.5 9.4-8 10-4.5-.6-8-5-8-10V6l8-4z\"/><path d=\"M8.5 12.3l2.2 2.2 4.8-5.2\"/></svg>\n      {{ trust_left }}\n    </span>\n    <span role=\"listitem\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M3 7l9-4 9 4-9 4-9-4z\"/><path d=\"M3 7v10l9 4 9-4V7\"/><path d=\"M12 11v10\"/></svg>\n      {{ trust_right }}\n    </span>\n  </div>\n</div>"

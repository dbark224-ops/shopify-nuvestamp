{
  "sections": {
    "custom_liquid_ifnqic": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "{%- comment -%}\nNUVE STAMP — Mobile Hero Final (Psychology-optimized)\nPaste into Shopify Custom Liquid. Mobile-only block.\n{%- endcomment -%}\n\n<div id=\"buy\" style=\"position: relative; top: -90px;\"></div>\n\n{%- assign btn_text = 'See Price & Buy Now' -%}\n{%- assign rating_text = '4.9/5' -%}\n{%- assign rating_sub = 'Trusted by 5,000+ customers' -%}\n{%- assign trust_left = '30-Day Money-Back Guarantee' -%}\n{%- assign trust_right = 'Free Shipping' -%}\n\n{%- assign sale_price = product.price -%}\n{%- assign compare_price = product.compare_at_price_max -%}\n{%- assign pct_off = 0 -%}\n{%- assign savings = 0 -%}\n{%- if compare_price > sale_price -%}\n  {%- assign savings = compare_price | minus: sale_price -%}\n  {%- assign pct_off = savings | times: 100.0 | divided_by: compare_price | round -%}\n{%- endif -%}\n\n<style>\n  .nuve-mobile-hero{\n    display:block;\n    margin:12px 16px 0;\n    padding:14px;\n    border-radius:16px;\n    background:rgba(201,183,255,0.22);\n    border:1px solid rgba(201,183,255,0.45);\n  }\n  .nuve-mh-headline{\n    margin:0 0 10px;\n    font-size:28px;\n    line-height:1.05;\n    font-weight:900;\n    color:#111;\n    letter-spacing:-0.3px;\n  }\n  .nuve-mh-sub{\n    margin:0 0 10px;\n    font-size:13px;\n    font-weight:700;\n    color:rgba(17,17,17,.75);\n  }\n  .nuve-mh-stars{display:flex;align-items:center;gap:8px;line-height:1;margin:0 0 8px;}\n  .nuve-mh-stars .stars{display:flex;gap:3px;}\n  .nuve-mh-stars svg{width:14px;height:14px;fill:#F5A623;display:block;}\n  .nuve-mh-rating{font-size:13px;font-weight:800;color:#111;white-space:nowrap;}\n\n  .nuve-mh-price{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin:0 0 12px;line-height:1;}\n  .nuve-mh-price .sale{font-size:28px;font-weight:900;color:#111;}\n  .nuve-mh-price .compare{font-size:18px;font-weight:700;color:rgba(17,17,17,.45);text-decoration:line-through;}\n  .nuve-mh-price .off{font-size:11px;font-weight:800;color:#111;background:#fff;border:1px solid rgba(17,17,17,.14);border-radius:9999px;padding:5px 8px;}\n\n  .nuve-mh-save{margin:0 0 10px;font-size:12px;font-weight:800;color:#111;}\n  .nuve-mh-save .pill{display:inline-block;background:#fff;border:1px solid rgba(17,17,17,.14);border-radius:999px;padding:4px 8px;}\n\n  .nuve-mh-btn{\n    width:100%;display:flex;align-items:center;justify-content:center;\n    padding:14px 16px;border-radius:9999px;background:#111;color:#fff;\n    text-decoration:none;font-size:16px;font-weight:900;line-height:1;\n    box-shadow:0 12px 26px rgba(0,0,0,.18);\n  }\n  .nuve-mh-micro{\n    margin:8px 0 0;\n    font-size:11.5px;\n    text-align:center;\n    color:rgba(17,17,17,.72);\n    font-weight:700;\n  }\n\n  .nuve-mh-trust{\n    display:flex;justify-content:center;gap:14px;margin-top:10px;flex-wrap:wrap;\n    font-size:12px;font-weight:700;color:rgba(17,17,17,.75);\n  }\n  .nuve-mh-trust span{display:inline-flex;align-items:center;gap:7px;white-space:nowrap;}\n  .nuve-mh-trust svg{width:16px;height:16px;stroke:rgba(17,17,17,.75);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;}\n\n  @media (min-width:750px){ .nuve-mobile-hero{display:none;} }\n</style>\n\n<div class=\"nuve-mobile-hero\">\n  <h2 class=\"nuve-mh-headline\">Thinning Hair? Start a Simple At-Home Routine for Fuller-Looking Regrowth</h2>\n  <p class=\"nuve-mh-sub\">Microneedling + red light + vibration • 5–10 min routine • 2–3x/week</p>\n\n  <div class=\"nuve-mh-stars\" aria-label=\"Rating {{ rating_text }}\">\n    <span class=\"stars\" aria-hidden=\"true\">\n      {% for i in (1..5) %}\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n      {% endfor %}\n    </span>\n    <span class=\"nuve-mh-rating\">{{ rating_text }}</span>\n  </div>\n  <p class=\"nuve-mh-sub\">{{ rating_sub }}</p>\n\n  <div class=\"nuve-mh-price\" aria-label=\"Price\">\n    <span class=\"sale\">{{ sale_price | money }}</span>\n    {% if compare_price > sale_price %}\n      <span class=\"compare\">{{ compare_price | money }}</span>\n      <span class=\"off\">{{ pct_off }}% OFF</span>\n    {% endif %}\n  </div>\n\n  {% if savings > 0 %}\n    <p class=\"nuve-mh-save\"><span class=\"pill\">Save {{ savings | money }} today</span></p>\n  {% endif %}\n\n  <a class=\"nuve-mh-btn\" href=\"#buy\">{{ btn_text }}</a>\n  <p class=\"nuve-mh-micro\">Limited Launch Offer • Free tracked shipping • 30-day guarantee</p>\n\n  <div class=\"nuve-mh-trust\" role=\"list\">\n    <span role=\"listitem\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 2l8 4v6c0 5-3.5 9.4-8 10-4.5-.6-8-5-8-10V6l8-4z\"/><path d=\"M8.5 12.3l2.2 2.2 4.8-5.2\"/></svg>\n      {{ trust_left }}\n    </span>\n    <span role=\"listitem\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M3 7l9-4 9 4-9 4-9-4z\"/><path d=\"M3 7v10l9 4 9-4V7\"/><path d=\"M12 11v10\"/></svg>\n      {{ trust_right }}\n    </span>\n  </div>\n</div>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }

            "custom_liquid_6xyykd": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{%- comment -%}\nStars + rating + subtext (matches screenshot).\nEdit the variables below to change the numbers/text.\n{%- endcomment -%}\n\n{%- assign rating_value = 4.9 -%}\n{%- assign rating_max = 5 -%}\n{%- assign rating_text = '4.9/5' -%}\n{%- assign subtext = 'Trusted by 5,000+ customers' -%}\n\n{%- style -%}\n  .nuve-rating-wrap{\n    display: inline-flex;\n    flex-direction: column;\n    gap: 6px;\n  }\n  .nuve-rating-top{\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .nuve-stars{\n    display: inline-flex;\n    gap: 4px;\n    line-height: 1;\n  }\n  .nuve-star{\n    width: 16px;\n    height: 16px;\n    display: inline-block;\n  }\n  .nuve-star svg{\n    width: 100%;\n    height: 100%;\n    display: block;\n    fill: #F5A623; /* warm gold like screenshot */\n  }\n  .nuve-rating-text{\n    font-size: 14px;\n    font-weight: 700;\n    color: #111;\n    line-height: 1;\n  }\n  .nuve-rating-subtext{\n    font-size: 13px;\n    font-weight: 500;\n    color: #111;\n    line-height: 1.2;\n  }\n{%- endstyle -%}\n\n<div class=\"nuve-rating-wrap\" aria-label=\"Rated {{ rating_text }}\">\n  <div class=\"nuve-rating-top\">\n    <div class=\"nuve-stars\" role=\"img\" aria-label=\"{{ rating_value }} out of {{ rating_max }} stars\">\n      {%- for i in (1..rating_max) -%}\n        <span class=\"nuve-star\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\" focusable=\"false\">\n            <path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/>\n          </svg>\n        </span>\n      {%- endfor -%}\n    </div>\n\n    <span class=\"nuve-rating-text\">{{ rating_text }}</span>\n  </div>\n\n  <div class=\"nuve-rating-subtext\">{{ subtext }}</div>\n</div>"

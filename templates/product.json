              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<style>\n  .nuve-eta{\n    margin-top: 10px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    font-size: 13px;\n    font-weight: 700;\n    color: rgba(17,17,17,.75);\n  }\n  .nuve-eta svg{\n    width: 18px;\n    height: 18px;\n    stroke: rgba(17,17,17,.75);\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    flex: 0 0 auto;\n  }\n</style>\n\n<div class=\"nuve-eta\" id=\"nuve-eta-line\" aria-live=\"polite\">\n  <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n    <path d=\"M3 7h11v10H3z\"></path>\n    <path d=\"M14 10h4l3 3v4h-7z\"></path>\n    <path d=\"M7 17a2 2 0 1 0 0 .01\"></path>\n    <path d=\"M18 17a2 2 0 1 0 0 .01\"></path>\n  </svg>\n  <span>\n    Free shipping - arrives\n    <span id=\"nuve-eta-range\">in 5-7 business days</span>\n  </span>\n</div>\n\n<script>\n  (function () {\n    function addBusinessDays(startDate, businessDays) {\n      const d = new Date(startDate.getTime());\n      let added = 0;\n      while (added < businessDays) {\n        d.setDate(d.getDate() + 1);\n        const day = d.getDay(); // 0=Sun, 6=Sat\n        if (day !== 0 && day !== 6) added++;\n      }\n      return d;\n    }\n\n    function fmt(date) {\n      // Example: Feb 26 (uses visitor's locale)\n      return date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });\n    }\n\n    const today = new Date();\n    const minDays = 5;\n    const maxDays = 7;\n\n    const etaMin = addBusinessDays(today, minDays);\n    const etaMax = addBusinessDays(today, maxDays);\n\n    const el = document.getElementById('nuve-eta-range');\n    if (!el) return;\n\n    // If same day (rare), show single date\n    const same = etaMin.toDateString() === etaMax.toDateString();\n    el.textContent = same ? fmt(etaMin) : (fmt(etaMin) + '–' + fmt(etaMax));\n  })();\n</script>"
              },
              "blocks": {}
            },
